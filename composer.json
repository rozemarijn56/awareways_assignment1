{
    "name": "marjolein/user-activity-pipeline",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8080 -t public",
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text",
        "test:coverage-html": "phpunit --coverage-html coverage"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "ramsey/uuid": "^4.9"
    }
}
